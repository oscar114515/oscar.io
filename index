            document.addEventListener('drop', e => {
                e.preventDefault();
                document.getElementById('emojiDragOverlay').style.opacity = 0;
                const file = e.dataTransfer.files[0];
                if (file) {
                    if (cameraOn) stopCamera();
                    const url = URL.createObjectURL(file);
                    if (file.type.includes('video')) { video.src = url;
                        setImgMode(false);
