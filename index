        })();


        // ============================================================
        // 2. crack 頁面邏輯
        // ============================================================
        (function() {
            const PROXY_LIST = [
                { name: 'CORS Anywhere (需授權)', url: 'https://cors-anywhere.herokuapp.com/' },
                { name: 'CORS Proxy', url: 'https://cors-proxy.htmldriven.com/?url=' },
                { name: 'All Origins', url: 'https://api.allorigins.win/raw?url=' },
                { name: 'ThingProxy', url: 'https://thingproxy.freeboard.io/fetch/' },
                { name: 'CORS Proxy 2', url: 'https://cors-proxy.learn.uno/?url=' },
                { name: 'CORS Anywhere Worker', url: 'https://cors-anywhere.azm.workers.dev/' },
                { name: 'CORS Proxy IO', url: 'https://corsproxy.io/?url=' }
            ];
            let proxyStatuses = [];
            let isChecking = false;
            let pendingUrl = '',
                pendingMode = '';

            const proxySelect = document.getElementById('crackProxySelect');
            const proxyStatus = document.getElementById('crackProxyStatus');
            const proxyNote = document.getElementById('crackProxyNote');
            const corsInfo = document.getElementById('corsInfo');
            const corsLink = document.getElementById('corsLink');
            const urlInput = document.getElementById('crackUrlInput');
            const fetchBtn = document.getElementById('crackFetchBtn');
            const errorDiv = document.getElementById('crackError');
            const loadingDiv = document.getElementById('crackLoading');
            const codeDisplay = document.getElementById('crackCodeDisplay');
            const urlDisplay = document.getElementById('crackUrlDisplay');
            const statsDisplay = document.getElementById('crackStats');
            const copyBtn = document.getElementById('crackCopyBtn');

            function getStatusSymbol(s) { return s === 'online' ? '🟢' : s === 'offline' ? '🔴' : '🟠'; }

            function updateProxyNote(s) {
                proxyNote.className = 'proxy-note';
                if (s === 'online') { proxyNote.className = 'proxy-note online';
                    proxyNote.innerHTML = '✅ 當前代理在線，可以使用'; } else if (s === 'offline') { proxyNote.className =
                        'proxy-note offline';
                    proxyNote.innerHTML = '⚠️ 當前代理離線，請切換其他代理'; } else { proxyNote.className = 'proxy-note checking';
                    proxyNote.innerHTML = '⏳ 檢測代理狀態中...'; }
            }

            function updateStatusDot(s) { proxyStatus.className = 'proxy-status-badge status-' + s; }

            function renderProxySelect() {
                proxySelect.innerHTML = '';
                const online = proxyStatuses.filter(p => p.status === 'online');
                if (online.length === 0) {
                    const opt = document.createElement('option');
                    opt.value = '-1';
                    opt.textContent = '⚠️ 無可用代理，請稍後再試';
                    proxySelect.appendChild(opt);
                    proxySelect.disabled = true;
                    updateStatusDot('offline');
                    updateProxyNote('offline');
                    return;
                }
                proxySelect.disabled = false;
                online.forEach((p, i) => {
                    const opt = document.createElement('option');
                    opt.value = i;
                    opt.textContent = p.name + ' ' + getStatusSymbol(p.status);
                    proxySelect.appendChild(opt);
                });
                const first = online[0];
                updateStatusDot(first.status);
                updateProxyNote(first.status);
                if (first.name.includes('CORS Anywhere')) corsInfo.classList.remove('hidden');
                else corsInfo.classList.add('hidden');
            }

            async function checkProxyStatus(proxy, idx) {
                try {
                    const c = new AbortController();
                    const t = setTimeout(() => c.abort(), 8000);
                    const r = await fetch(proxy.url + 'https://httpbin.org/get', { method: 'HEAD', mode: 'cors',
                        cache: 'no-cache', signal: c.signal });
                    clearTimeout(t);
                    proxyStatuses[idx].status = r.ok ? 'online' : 'offline';
                } catch (e) { proxyStatuses[idx].status = 'offline'; }
            }

            async function checkAllProxies() {
                if (isChecking) return;
                isChecking = true;
                proxyStatuses = PROXY_LIST.map(p => ({ name: p.name, url: p.url, status: 'unknown' }));
                await Promise.allSettled(PROXY_LIST.map((p, i) => checkProxyStatus(p, i)));
                renderProxySelect();
                isChecking = false;
            }

            function getCurrentProxyUrl() {
                const online = proxyStatuses.filter(p => p.status === 'online');
                if (online.length === 0) return null;
                const idx = proxySelect.selectedIndex;
                if (idx < 0 || idx >= online.length) return null;
                return online[idx].url;
            }

            const USER_AGENTS = {
                baidu: 'Mozilla/5.0 (compatible; Baiduspider/2.0; +http://www.baidu.com/search/spider.html)',
                google: 'Mozilla/5.0 (compatible; Googlebot/2.1; +http://www.google.com/bot.html)',
                normal: 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36',
                mobile: 'Mozilla/5.0 (iPhone; CPU iPhone OS 14_0 like Mac OS X) AppleWebKit/605.1.15'
            };

            function resetDisplay() {
                codeDisplay.textContent = '👆 輸入網址，點擊「抓取」進行人機驗證';
                codeDisplay.className = 'empty-state';
                urlDisplay.textContent = '';
                statsDisplay.textContent = '等待抓取';
                copyBtn.disabled = true;
            }

            function showError(msg) { errorDiv.style.display = 'block';
                errorDiv.innerHTML = msg;
                loadingDiv.style.display = 'none';
                fetchBtn.disabled = false;
                resetDisplay(); }

            function hideError() { errorDiv.style.display = 'none'; }

            function showLoading() {
                fetchBtn.disabled = true;
                loadingDiv.style.display = 'block';
                hideError();
                codeDisplay.textContent = '⏳ 抓取中...';
                codeDisplay.className = 'empty-state';
                statsDisplay.textContent = '抓取中';
            }

            function hideLoading() { fetchBtn.disabled = false;
                loadingDiv.style.display = 'none'; }

            function executeFetch() {
                const url = pendingUrl,
                    mode = pendingMode,
                    proxyUrl = getCurrentProxyUrl();
                if (!url || !proxyUrl) { showError('沒有可用的代理'); return; }
                showLoading();
                const xhr = new XMLHttpRequest();
                xhr.open('GET', proxyUrl + url);
                xhr.timeout = 30000;
                xhr.setRequestHeader('User-Agent', USER_AGENTS[mode]);
                xhr.setRequestHeader('X-Requested-With', 'XMLHttpRequest');
                xhr.onload = function() {
                    hideLoading();
                    if (xhr.status >= 200 && xhr.status < 300) {
                        const text = xhr.responseText;
                        codeDisplay.textContent = text;
                        codeDisplay.className = '';
                        urlDisplay.textContent = '(' + url + ')';
                        statsDisplay.textContent = xhr.status + ' | ' + (text.length / 1024).toFixed(2) + 'KB | ' +
                            mode;
                        copyBtn.disabled = false;
                    } else { showError('錯誤 ' + xhr.status + ' - ' + (xhr.statusText || '代理可能失效')); }
                };
                xhr.onerror = () => showError('網路錯誤，請檢查連線');
                xhr.ontimeout = () => showError('連線超時，請稍後再試');
                xhr.send();
            }

            function handleFetchClick() {
                const url = urlInput.value.trim();
                const mode = document.querySelector('input[name="crackMode"]:checked').value;
                if (!url) { showError('請輸入網址'); return; }
                if (!url.startsWith('http://') && !url.startsWith('https://')) { showError('網址須以 http:// 或 https:// 開頭');
                    return; }
                pendingUrl = url;
                pendingMode = mode;
                document.getElementById('crackCaptchaModal').style.display = 'flex';
                document.body.style.overflow = 'hidden';
            }

            window.onCrackCaptchaSuccess = function(token) {
                document.getElementById('crackCaptchaModal').style.display = 'none';
                document.body.style.overflow = 'auto';
                if (typeof hcaptcha !== 'undefined') hcaptcha.reset();
                executeFetch();
            };

            document.getElementById('crackCaptchaModal').addEventListener('click', function(e) {
                if (e.target === this) {
                    this.style.display = 'none';
                    document.body.style.overflow = 'auto';
                    if (typeof hcaptcha !== 'undefined') hcaptcha.reset();
                }
            });

            proxySelect.addEventListener('change', function() {
                const online = proxyStatuses.filter(p => p.status === 'online');
                if (online.length === 0) return;
                const idx = this.selectedIndex;
                if (idx < 0 || idx >= online.length) return;
                const selected = online[idx];
                updateStatusDot(selected.status);
                updateProxyNote(selected.status);
                if (selected.name.includes('CORS Anywhere')) corsInfo.classList.remove('hidden');
                else corsInfo.classList.add('hidden');
            });

            corsLink.addEventListener('click', () => setTimeout(checkAllProxies, 3000));
            copyBtn.addEventListener('click', () => {
                const text = codeDisplay.textContent;
                if (text.includes('輸入網址') || text.includes('抓取中')) return;
                navigator.clipboard.writeText(text).then(() => {
                    copyBtn.textContent = '✓ 已複製';
                    setTimeout(() => copyBtn.textContent = '複製', 1500);
                });
            });
            fetchBtn.addEventListener('click', handleFetchClick);
            urlInput.addEventListener('keypress', e => e.key === 'Enter' && handleFetchClick());

            resetDisplay();
            checkAllProxies();
            setInterval(checkAllProxies, 60000);
        })();


        // ============================================================
        // 3. xmas 頁面邏輯 (3D 聖誕樹 + 手勢)
        // ============================================================
        (function() {
            // 防止重複初始化
            if (window._xmasLoaded) return;
            window._xmasLoaded = true;

            const loadingEl = document.getElementById('xmasLoading');
            const video = document.getElementById('xmasVideoFeed');
            const canvas = document.getElementById('xmasSkeletonCanvas');
            const ctx = canvas.getContext('2d');
            const photoCountSpan = document.getElementById('xmasPhotoCount');
            const GOLD = '#D4AF37';
            let currentGesture = 'unknown';

            const HAND_CONNECTIONS = [
                [0, 1], [1, 2], [2, 3], [3, 4], [0, 5], [5, 6], [6, 7], [7, 8],
                [0, 9], [9, 10], [10, 11], [11, 12], [0, 13], [13, 14], [14, 15], [15, 16],
                [0, 17], [17, 18], [18, 19], [19, 20], [5, 9], [9, 13], [13, 17]
            ];
            const FINGER_TIPS = [4, 8, 12, 16, 20];

            function recognizeGesture(landmarks) {
                if (!landmarks) return 'unknown';
                const idx = landmarks[8],
                    ip = landmarks[6],
                    mt = landmarks[12],
                    mp = landmarks[10],
                    rt = landmarks[16],
                    rp = landmarks[14],
                    pt = landmarks[20],
                    pp = landmarks[18],
                    tt = landmarks[4];
                const idxStraight = idx.y < ip.y,
                    midStraight = mt.y < mp.y,
                    ringStraight = rt.y < rp.y,
                    pinkyStraight = pt.y < pp.y;
                const curled = [idx.y > ip.y, mt.y > mp.y, rt.y > rp.y, pt.y > pp.y].filter(Boolean).length;
                const dist = Math.sqrt((tt.x - idx.x) ** 2 + (tt.y - idx.y) ** 2);
                if (curled >= 3) return 'fist';
                if (idxStraight && midStraight && ringStraight && pinkyStraight) return 'open';
                if (idxStraight && midStraight && !ringStraight && !pinkyStraight) return 'victory';
                if (dist < 0.1) return 'pinch';
                return 'unknown';
            }

            function drawHand(landmarks) {
                ctx.clearRect(0, 0, canvas.width, canvas.height);
                if (!landmarks) return;
                const pts = landmarks.map(p => ({ x: p.x * canvas.width, y: p.y * canvas.height }));
                let minX = canvas.width,
                    minY = canvas.height,
                    maxX = 0,
                    maxY = 0;
                pts.forEach(p => { if (p.x < minX) minX = p.x; if (p.y < minY) minY = p.y; if (p.x > maxX) maxX = p.x; if (p
                        .y > maxY) maxY = p.y; });
                const pad = 10;
                minX = Math.max(0, minX - pad);
                minY = Math.max(0, minY - pad);
                maxX = Math.min(canvas.width, maxX + pad);
                maxY = Math.min(canvas.height, maxY + pad);
                ctx.beginPath();
                ctx.strokeStyle = GOLD;
                ctx.lineWidth = 2;
                ctx.shadowBlur = 8;
                ctx.shadowColor = 'gold';
                HAND_CONNECTIONS.forEach(([s, e]) => {
                    const p1 = pts[s],
                        p2 = pts[e];
                    if (p1 && p2) { ctx.moveTo(p1.x, p1.y);
                        ctx.lineTo(p2.x, p2.y); }
                });
                ctx.stroke();
                pts.forEach((p, i) => {
                    ctx.beginPath();
                    ctx.arc(p.x, p.y, FINGER_TIPS.includes(i) ? 5 : 3, 0, 2 * Math.PI);
                    ctx.fillStyle = GOLD;
                    ctx.shadowBlur = 10;
                    ctx.fill();
                    ctx.strokeStyle = '#fff';
                    ctx.lineWidth = 1;
                    ctx.stroke();
                });
                ctx.shadowBlur = 10;
                ctx.strokeStyle = GOLD;
                ctx.lineWidth = 2;
                ctx.strokeRect(minX, minY, maxX - minX, maxY - minY);
                ctx.shadowBlur = 0;
            }

            // MediaPipe Hands 初始化
            async function initHandTracking() {
                try {
                    const hands = new Hands({
                        locateFile: (file) => 'https://cdn.jsdelivr.net/npm/@mediapipe/hands/' + file
                    });
                    hands.setOptions({
                        selfieMode: true,
                        maxNumHands: 1,
                        modelComplexity: 1,
                        minDetectionConfidence: 0.5,
                        minTrackingConfidence: 0.5
                    });
                    hands.onResults((results) => {
                        if (results.multiHandLandmarks && results.multiHandLandmarks.length > 0) {
                            const lm = results.multiHandLandmarks[0];
                            drawHand(lm);
                            const g = recognizeGesture(lm);
                            if (g !== currentGesture) {
                                currentGesture = g;
                                // 控制 Three.js 場景（由 module script 處理）
                                window.dispatchEvent(new CustomEvent('xmasGesture', { detail: { gesture: g } }));
                            }
                        } else { ctx.clearRect(0, 0, canvas.width, canvas.height); }
                    });
                    const camera = new Camera(video, {
                        onFrame: async () => { await hands.send({ image: video }); },
                        width: 320,
                        height: 240
                    });
                    await camera.start();
                    canvas.width = video.videoWidth || 320;
                    canvas.height = video.videoHeight || 240;
                    loadingEl.classList.add('hidden');
                } catch (err) {
                    console.warn('手势启动失败', err);
                    loadingEl.classList.add('hidden');
                }
            }

            // 照片上傳
            document.getElementById('xmasFileInput').addEventListener('change', function(e) {
                const files = e.target.files;
                if (!files.length) return;
                photoCountSpan.textContent = files.length;
                // 將照片傳遞給 Three.js 場景
                window.dispatchEvent(new CustomEvent('xmasPhotos', { detail: { files: Array.from(files) } }));
            });

            // 啟動手勢
            initHandTracking();

            // 點擊預覽切換全屏（簡化）
            document.getElementById('xmasHandPreview').addEventListener('click', function() {
                if (document.fullscreenElement) document.exitFullscreen();
                else this.requestFullscreen();
            });

            // Three.js 場景（動態載入）
            const script = document.createElement('script');
            script.type = 'module';
            script.textContent = `
                import * as THREE from 'three';
                import { OrbitControls } from 'three/addons/controls/OrbitControls.js';
                import { EffectComposer } from 'three/addons/postprocessing/EffectComposer.js';
                import { RenderPass } from 'three/addons/postprocessing/RenderPass.js';
                import { UnrealBloomPass } from 'three/addons/postprocessing/UnrealBloomPass.js';

                let scene, camera, renderer, composer, controls;
                let particles, particleGeo;
                let photoMeshes = [];
                let time = 0;
                let currentState = 'SCATTER';
                let targetPhotoIndex = 0;
                const PARTICLE_COUNT = 2500;
                const GOLD = '#D4AF37';

                function initThree() {
                    const canvas = document.getElementById('xmasGlCanvas');
                    renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: false });
                    renderer.setSize(window.innerWidth, window.innerHeight);
                    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
                    renderer.setClearColor(0x050505, 1);
                    scene = new THREE.Scene();
                    scene.background = new THREE.Color(0x050505);
                    scene.fog = new THREE.FogExp2(0x050505, 0.015);
                    camera = new THREE.PerspectiveCamera(60, window.innerWidth / window.innerHeight, 0.1, 1000);
                    camera.position.set(8, 5, 18);
                    camera.lookAt(0, 2, 0);
                    controls = new OrbitControls(camera, renderer.domElement);
                    controls.enableDamping = true;
                    controls.autoRotate = true;
                    controls.autoRotateSpeed = 0.6;
                    controls.target.set(0, 2, 0);
                    controls.enableZoom = true;
                    controls.maxPolarAngle = Math.PI / 2.2;
                }

                function initPost() {
                    const renderScene = new RenderPass(scene, camera);
                    const bloom = new UnrealBloomPass(new THREE.Vector2(window.innerWidth, window.innerHeight), 1.2, 0.3, 0.85);
                    bloom.threshold = 0.1;
                    bloom.strength = 0.9;
                    bloom.radius = 0.4;
                    composer = new EffectComposer(renderer);
                    composer.addPass(renderScene);
                    composer.addPass(bloom);
                }

                function createParticles() {
                    const geo = new THREE.BufferGeometry();
                    const pos = [], colors = [], randomTargets = [], treeTargets = [];
                    const gold = new THREE.Color(0xD4AF37), green = new THREE.Color(0x2E7D32);
                    const white = new THREE.Color(0xFFFFFF), red = new THREE.Color(0xC62828);
                    const opts = [gold, green, white, red];
                    for (let i = 0; i < PARTICLE_COUNT; i++) {
                        const x = (Math.random() - 0.5) * 30, y = (Math.random() - 0.5) * 20 + 2, z = (Math.random() - 0.5) * 30;
                        pos.push(x, y, z);
                        randomTargets.push(x, y, z);
                        const t = i / PARTICLE_COUNT, angle = i * 0.25;
                        const radius = 5.5 * (1 - t * 0.8), h = t * 14 - 4;
                        const tx = Math.cos(angle) * radius, tz = Math.sin(angle) * radius, ty = h;
                        treeTargets.push(tx, ty, tz);
                        const c = opts[Math.floor(Math.random() * opts.length)];
                        colors.push(c.r, c.g, c.b);
                    }
                    geo.setAttribute('position', new THREE.Float32BufferAttribute(pos, 3));
                    geo.setAttribute('color', new THREE.Float32BufferAttribute(colors, 3));
                    geo.userData = { randomTargets, treeTargets };
                    const map = new THREE.TextureLoader().load('https://threejs.org/examples/textures/sprites/spark1.png');
                    const mat = new THREE.PointsMaterial({
                        size: 0.4,
                        map: map,
                        vertexColors: true,
                        blending: THREE.AdditiveBlending,
                        depthWrite: false,
                        transparent: true,
                        sizeAttenuation: true
                    });
                    particles = new THREE.Points(geo, mat);
                    scene.add(particles);
                    particleGeo = geo;
                }

                function createLighting() {
                    scene.add(new THREE.AmbientLight(0x404060));
                    const spot = new THREE.SpotLight(0xffaa33, 20);
                    spot.position.set(5, 15, 10);
                    scene.add(spot);
                    const point = new THREE.PointLight(0xff6600, 10, 20);
                    point.position.set(0, 5, 0);
                    scene.add(point);
                }

                function addPhotos(files) {
                    photoMeshes.forEach(m => scene.remove(m));
                    photoMeshes = [];
                    files.forEach(file => {
                        const reader = new FileReader();
                        reader.onload = (evt) => {
                            const tex = new THREE.TextureLoader().load(evt.target.result);
                            const img = new Image();
                            img.src = evt.target.result;
                            img.onload = () => {
                                const aspect = img.width / img.height;
                                const geo = new THREE.PlaneGeometry(2.2, 2.2 / aspect);
                                const mat = new THREE.MeshBasicMaterial({ map: tex, side: THREE.DoubleSide,
                                    transparent: true });
                                const mesh = new THREE.Mesh(geo, mat);
                                mesh.position.set((Math.random() - 0.5) * 10, Math.random() * 6, (Math.random() -
                                    0.5) * 10);
                                scene.add(mesh);
                                photoMeshes.push(mesh);
                            };
                        };
                        reader.readAsDataURL(file);
                    });
                }

                function animate() {
                    requestAnimationFrame(animate);
                    time += 0.012;
                    if (particleGeo) {
                        const pos = particleGeo.attributes.position.array;
                        const { randomTargets, treeTargets } = particleGeo.userData;
                        for (let i = 0; i < pos.length; i += 3) {
                            const idx = i / 3;
                            let tx, ty, tz;
                            if (currentState === 'TREE' || currentState === 'GALLERY') {
                                tx = treeTargets[idx * 3];
                                ty = treeTargets[idx * 3 + 1] + Math.sin(time * 2 + tx) * 0.1;
                                tz = treeTargets[idx * 3 + 2];
                            } else {
                                tx = randomTargets[idx * 3];
                                ty = randomTargets[idx * 3 + 1] + Math.sin(time + idx) * 0.05;
                                tz = randomTargets[idx * 3 + 2];
                            }
                            pos[i] += (tx - pos[i]) * 0.04;
                            pos[i + 1] += (ty - pos[i + 1]) * 0.04;
                            pos[i + 2] += (tz - pos[i + 2]) * 0.04;
                        }
                        particleGeo.attributes.position.needsUpdate = true;
                    }
                    if (currentState === 'FOCUS' && photoMeshes.length > 0) {
                        photoMeshes.forEach((mesh, i) => {
                            if (i === targetPhotoIndex) {
                                const dir = new THREE.Vector3();
                                camera.getWorldDirection(dir);
                                mesh.position.lerp(camera.position.clone().add(dir.multiplyScalar(4)), 0.1);
                                mesh.quaternion.copy(camera.quaternion);
                            }
                        });
                    }
                    controls.update();
                    composer.render();
                }

                function start() {
                    initThree();
                    initPost();
                    createParticles();
                    createLighting();
                    animate();

                    window.addEventListener('resize', () => {
                        camera.aspect = window.innerWidth / window.innerHeight;
                        camera.updateProjectionMatrix();
                        renderer.setSize(window.innerWidth, window.innerHeight);
                        composer.setSize(window.innerWidth, window.innerHeight);
                    });

                    // 監聽手勢事件
                    window.addEventListener('xmasGesture', (e) => {
                        const g = e.detail.gesture;
                        if (g === 'fist') { currentState = 'TREE';
                            controls.autoRotate = true; }
                        else if (g === 'open') { currentState = 'SCATTER';
                            controls.autoRotate = false; }
                        else if (g === 'victory') { currentState = 'GALLERY';
                            controls.autoRotate = true; }
                        else if (g === 'pinch') {
                            currentState = 'FOCUS';
                            if (photoMeshes.length > 0) {
                                targetPhotoIndex = (targetPhotoIndex + 1) % photoMeshes.length;
                            }
                        }
                    });

                    // 監聽照片上傳
                    window.addEventListener('xmasPhotos', (e) => {
                        addPhotos(e.detail.files);
                        document.getElementById('xmasPhotoCount').textContent = e.detail.files.length;
                    });
                }

                start();
            `;
