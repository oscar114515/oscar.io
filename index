                grid.innerHTML = '';
                for (const [line, info] of Object.entries(LINE_STATIONS)) {
                    const card = document.createElement('div');
                    card.className = 'mtr-card';
                    card.style.setProperty('--line-color', LINE_COLORS[line] || '#888');
                    const header = document.createElement('div');
                    header.className = 'mtr-card-header';
                    const nameSpan = document.createElement('span');
                    nameSpan.className = 'line-name';
                    const dot = document.createElement('span');
                    dot.className = 'dot';
                    dot.style.background = LINE_COLORS[line] || '#888';
                    nameSpan.textContent = info.name;
                    nameSpan.prepend(dot);
                    const codeSpan = document.createElement('span');
                    codeSpan.className = 'line-code';
                    codeSpan.textContent = line;
                    header.appendChild(nameSpan);
                    header.appendChild(codeSpan);
                    card.appendChild(header);
                    const stationDiv = document.createElement('div');
                    stationDiv.className = 'mtr-stations';
                    info.stations.forEach(st => {
                        const btn = document.createElement('button');
                        if (st === selected[line]) btn.classList.add('active');
                        btn.textContent = getChineseName(st);
                        btn.dataset.station = st;
                        btn.dataset.line = line;
                        btn.addEventListener('click', function(e) {
                            const lineKey = this.dataset.line;
                            const stKey = this.dataset.station;
                            this.parentElement.querySelectorAll('button').forEach(b => b.classList.remove(
                                'active'));
                            this.classList.add('active');
                            selected[lineKey] = stKey;
                            fetchLineData(lineKey);
                        });
                        stationDiv.appendChild(btn);
                    });
                    card.appendChild(stationDiv);
                    const schedule = document.createElement('div');
                    schedule.className = 'mtr-schedule';
                    schedule.id = 'mtr-schedule-' + line;
                    schedule.innerHTML = '<div class="mtr-empty">載入中...</div>';
                    card.appendChild(schedule);
                    grid.appendChild(card);
                }
            }

            function updateScheduleUI(line) {
                const container = document.getElementById('mtr-schedule-' + line);
                if (!container) return;
                const station = selected[line];
                if (!station || !data[line] || !data[line][station]) {
                    container.innerHTML = '<div class="mtr-empty">暫無數據</div>';
                    return;
                }
                const stData = data[line][station];
                let html = '';
                ['UP', 'DOWN'].forEach(dir => {
                    const trains = stData[dir];
                    const isTerm = isTerminal(line, station, dir);
                    const label = dir === 'UP' ? '上行' : '下行';
                    html += `<div class="mtr-dir"><div class="mtr-dir-label">${label} <span>往</span></div>`;
                    if (!trains || trains.length === 0) {
                        html += isTerm ? `<div class="mtr-terminal">本站為 ${label} 終點站</div>` :
                            `<div class="mtr-empty">暫無列車</div>`;
                    } else {
                        trains.slice(0, 4).forEach(t => {
                            const dest = getChineseName(t.dest || '---');
                            const time = (t.time || '--:--:--').split(' ')[1] || t.time || '--:--';
                            html +=
                                `<div class="mtr-train"><span class="dest">${dest}</span><span class="time">${time}</span><span class="plat">P${t.plat||'-'}</span><span class="seq">#${t.seq||''}</span></div>`;
                        });
                    }
                    html += '</div>';
                });
                container.innerHTML = html;
            }

            async function fetchLineData(line) {
                const station = selected[line];
                if (!station) return;
                const url =
                `https://rt.data.gov.hk/v1/transport/mtr/getSchedule.php?line=${line}&sta=${station}&lang=tc`;
                try {
                    const resp = await fetch(url);
                    if (!resp.ok) throw new Error('HTTP ' + resp.status);
                    const json = await resp.json();
                    if (json.status === 0) {
                        const msg = json.message || '服務暫停';
                        if (!data[line]) data[line] = {};
                        data[line][station] = { UP: [], DOWN: [], error: msg };
                        updateScheduleUI(line);
                        showMtrError('[' + line + '] ' + msg);
                        return;
                    }
                    const raw = json.data || {};
                    const key = line + '-' + station;
                    const stData = raw[key] || raw[line + '-' + station] || {};
                    const up = Array.isArray(stData.UP) ? stData.UP : (stData.UP ? [stData.UP] : []);
                    const down = Array.isArray(stData.DOWN) ? stData.DOWN : (stData.DOWN ? [stData.DOWN] : []);
                    if (!data[line]) data[line] = {};
                    data[line][station] = {
                        UP: up.map(i => ({ dest: i.dest || '', time: i.time || '', plat: i.plat || '',
                            seq: i.seq || '' })),
                        DOWN: down.map(i => ({ dest: i.dest || '', time: i.time || '', plat: i.plat || '',
                            seq: i.seq || '' }))
                    };
                    if (json.curr_time) timeSpan.textContent = json.curr_time;
                    else if (json.sys_time) timeSpan.textContent = json.sys_time;
                    updateScheduleUI(line);
                    hideMtrError();
                } catch (err) {
                    if (!data[line]) data[line] = {};
                    data[line][station] = { UP: [], DOWN: [], error: '無法連線' };
                    updateScheduleUI(line);
                    showMtrError('[' + line + '] 無法取得數據: ' + err.message);
                }
            }

            function refreshAllMtr() {
                for (const line of Object.keys(LINE_STATIONS)) {
                    if (selected[line]) fetchLineData(line);
                }
            }

            let mtrErrorTimeout = null;

            function showMtrError(msg) {
                errorContainer.style.display = 'block';
                errorContainer.textContent = msg;
                clearTimeout(mtrErrorTimeout);
                mtrErrorTimeout = setTimeout(() => { errorContainer.style.display = 'none'; }, 8000);
            }

            function hideMtrError() { errorContainer.style.display = 'none';
                clearTimeout(mtrErrorTimeout); }

            document.getElementById('mtrRefreshAllBtn').addEventListener('click', refreshAllMtr);
            renderCards();
            refreshAllMtr();
            setInterval(refreshAllMtr, 60000);
        })();
    </script>

</body>
</html>
