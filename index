    <!-- ================================================================ -->
    <!-- ===== JavaScript（所有功能） ===== -->
    <!-- ================================================================ -->
    <script>
        // ============================================================
        // 0. 頁面切換 & 導航
        // ============================================================
        function switchPage(pageId) {
            document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
            const target = document.getElementById('page-' + pageId);
            if (target) target.classList.add('active');
            // 如果有滾動，回到頂部
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        // 導航欄聯繫我們
        document.getElementById('contactBtnNav').addEventListener('click', function(e) {
            e.preventDefault();
            document.getElementById('globalModal').style.display = 'flex';
            document.body.style.overflow = 'hidden';
        });
        document.getElementById('globalModal').addEventListener('click', function(e) {
            if (e.target === this) {
                this.style.display = 'none';
                document.body.style.overflow = 'auto';
            }
        });
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape' && document.getElementById('globalModal').style.display === 'flex') {
                document.getElementById('globalModal').style.display = 'none';
                document.body.style.overflow = 'auto';
            }
        });
        // 彈窗內按鈕
        document.getElementById('modalBili').onclick = () => window.open('https://space.bilibili.com/3632309945239723',
        '_blank');
        document.getElementById('modalXhs').onclick = () => window.open('https://xhslink.com/m/5aECPzZiqGQ', '_blank');
        document.getElementById('modalDouyin').onclick = () => window.open('https://v.douyin.com/HDdZvMmGXwU/', '_blank');
        document.getElementById('modalYt').onclick = () => window.open('https://www.youtube.com/@%E6%A2%81%E5%96%86%E5%90%8C%E5%AD%B8',
            '_blank');

        // ============================================================
        // 1. emoji 頁面邏輯
        // ============================================================
        (function() {
            const video = document.getElementById('emojiVideo');
            const img = document.getElementById('emojiImg');
            const canvas = document.getElementById('emojiCanvas');
            const ctx = canvas.getContext('2d');
            const screen = document.getElementById('emojiASCIIScreen');
            let compression = 16;
            let imgMode = false;
            let cameraOn = false;
            let cameraFacing = 'environment';
            const refColorList = [
                [232, 66, 86],
                [252, 134, 74],
                [239, 191, 76],
                [92, 222, 149],
                [72, 134, 214],
                [132, 102, 192],
                [136, 88, 86],
                [0, 0, 0],
                [255, 255, 255]
            ];
            const charList = ['🔴', '🟠', '🟡', '🟢', '🔵', '🟣', '🟤', '⚫', '⚪'];

            function refreshScreen() {
                if (imgMode) ctx.drawImage(img, 0, 0, canvas.width, canvas.height);
                else ctx.drawImage(video, 0, 0, canvas.width, canvas.height);
                const imageData = ctx.getImageData(0, 0, canvas.width, canvas.height);
                const data = imageData.data;
                const w = canvas.width,
                    h = canvas.height;
                let result = '';
                for (let i = 0; i < h; i += compression) {
                    for (let j = 0; j < w; j += compression) {
                        const idx = (i * w + j) * 4;
                        const r = data[idx],
                            g = data[idx + 1],
                            b = data[idx + 2];
                        let best = -1,
                            bestChar = '';
                        for (let k = 0; k < refColorList.length; k++) {
                            const diff = (r - refColorList[k][0]) ** 2 + (g - refColorList[k][1]) ** 2 + (b - refColorList[k][
                                2]) ** 2;
                            if (diff < best || best === -1) { best = diff;
                                bestChar = charList[k]; }
                        }
                        result += bestChar;
                    }
                    result += '<br>';
                }
                screen.innerHTML = result;
            }

            function setImgMode(isImg) {
                imgMode = isImg;
                const wrapper = document.getElementById('emojiVideoWrapper');
                const imgWrapper = document.getElementById('emojiImgWrapper');
                if (isImg) {
                    wrapper.style.display = 'none';
                    imgWrapper.style.display = 'block';
                    canvas.width = img.width * 2;
                    canvas.height = img.height * 2;
                    document.getElementById('emojiCompression').min = 1;
                    if (compression < 1) compression = 1;
                } else {
                    wrapper.style.display = 'block';
                    imgWrapper.style.display = 'none';
                    canvas.width = video.videoWidth || 640;
                    canvas.height = video.videoHeight || 480;
                    document.getElementById('emojiCompression').min = 4;
                    if (compression < 4) compression = 4;
                }
            }

            const loop = setInterval(() => {
                if (!imgMode && (video.paused || video.ended)) return;
                refreshScreen();
            }, 1000 / 30);

            function stopCamera() {
                video.pause();
                if (video.srcObject && video.srcObject.getTracks) {
                    video.srcObject.getTracks()[0].stop();
                    video.srcObject = null;
                }
                cameraOn = false;
                document.getElementById('emojiUseCamera').textContent = '📷 调用相机';
            }

            document.getElementById('emojiSelectVideo').onclick = function() {
                if (cameraOn) stopCamera();
                const input = document.createElement('input');
                input.type = 'file';
                input.accept = 'video/*';
                input.onchange = e => {
                    video.src = URL.createObjectURL(e.target.files[0]);
                };
                input.click();
            };
            document.getElementById('emojiSelectImage').onclick = function() {
                if (cameraOn) stopCamera();
                const input = document.createElement('input');
                input.type = 'file';
                input.accept = 'image/*';
                input.onchange = e => {
                    img.src = URL.createObjectURL(e.target.files[0]);
                };
                input.click();
            };
            document.getElementById('emojiUseCamera').onclick = function() {
                if (cameraOn) { stopCamera(); return; }
                navigator.mediaDevices.getUserMedia({ video: { facingMode: { exact: cameraFacing } } })
                    .then(stream => {
                        video.srcObject = stream;
                        setImgMode(false);
                        video.play();
                        cameraOn = true;
                        this.textContent = '📴 关闭相机';
                    })
                    .catch(() => alert('相机调用失败'));
            };
            document.getElementById('emojiSwitchCamera').onclick = function() {
                if (cameraOn) stopCamera();
                cameraFacing = cameraFacing === 'environment' ? 'user' : 'environment';
                document.getElementById('emojiUseCamera').click();
            };
            document.getElementById('emojiCopyScreen').onclick = function() {
                const text = screen.innerHTML.replace(/<br>/g, '\n');
                navigator.clipboard.writeText(text).then(() => alert('字符画已复制'));
            };
            document.getElementById('emojiFullscreen').onclick = function() {
                if (document.fullscreenElement) document.exitFullscreen();
                else screen.requestFullscreen();
            };
            document.getElementById('emojiFontSize').oninput = function() {
                const size = this.value;
                screen.style.fontSize = size + 'px';
                screen.style.lineHeight = size + 'px';
            };
            document.getElementById('emojiCompression').oninput = function() {
                compression = parseInt(this.value);
                refreshScreen();
            };
            video.onloadedmetadata = () => { setImgMode(false);
