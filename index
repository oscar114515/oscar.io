<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>梁喆同學 · 所有作品</title>

    <!-- Font Awesome 6 (免費版) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    
    <!-- hCaptcha (for crack.html) -->
    <script src="https://js.hcaptcha.com/1/api.js" async defer></script>

    <!-- MediaPipe (for xmas.html) -->
    <script src="https://cdn.jsdelivr.net/npm/@mediapipe/hands/hands.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@mediapipe/camera_utils/camera_utils.js"></script>

    <!-- Three.js (for xmas.html) -->
    <script type="importmap">
        {
            "imports": {
                "three": "https://unpkg.com/three@0.128.0/build/three.module.js",
                "three/addons/": "https://unpkg.com/three@0.128.0/examples/jsm/"
            }
        }
    </script>

    <style>
        /* ===== 全域重置 ===== */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background-color: #f0f2f5;
            font-family: system-ui, -apple-system, 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif;
            min-height: 100vh;
            padding-top: 80px;
        }

        /* ===== 導航欄（固定頂部） ===== */
        .navbar-wrapper {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            transform: translateY(-100%);
            animation: slideDown 0.5s ease-out forwards;
            z-index: 4000;
            background-color: #f8f9fa;
            border-bottom: 1px solid #ddd;
            padding: 0.5rem 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        @keyframes slideDown {
            0% { transform: translateY(-100%); }
            100% { transform: translateY(0); }
        }

        .navbar-wrapper .logo a {
            display: flex;
            align-items: center;
        }

        .navbar-wrapper .logo img {
            height: 50px;
            width: auto;
            display: block;
        }

        .navbar-wrapper .nav-links {
            display: flex;
            gap: 1.5rem;
            list-style: none;
            align-items: center;
            flex-wrap: wrap;
        }

        .navbar-wrapper .nav-links a {
            text-decoration: none;
            color: #007bff;
            font-size: 0.9rem;
            cursor: pointer;
            white-space: nowrap;
        }

        .navbar-wrapper .nav-links a:hover {
            color: #0056b3;
            text-decoration: underline;
        }

        /* 主頁按鈕突出 */
        .nav-links .home-link {
            font-weight: 600;
            color: #0b1b33 !important;
        }

        /* ===== 頁面容器 ===== */
        .page {
            display: none;
            max-width: 1400px;
            margin: 0 auto;
            padding: 20px;
            animation: fadeUp 0.35s ease;
        }

        .page.active {
            display: block;
        }

        @keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(16px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* 頁面內的卡片包裝（保持統一風格） */
        .page .card {
            background-color: white;
            border-radius: 12px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
            padding: 30px;
            width: 100%;
            margin: 0 auto;
        }

        /* ===== 主頁封面樣式 ===== */
        .hero-page .hero {
            background: linear-gradient(145deg, #ffffff 0%, #f8faff 100%);
            border-radius: 32px;
            padding: 50px 40px 40px;
            text-align: center;
            box-shadow: 0 20px 60px rgba(0, 20, 40, 0.08);
            border: 1px solid rgba(255, 255, 255, 0.6);
            position: relative;
            overflow: hidden;
        }

        .hero-page .hero::before {
            content: '';
            position: absolute;
            top: -60%;
            right: -20%;
            width: 500px;
            height: 500px;
            background: radial-gradient(circle, rgba(0, 102, 204, 0.04) 0%, transparent 70%);
            border-radius: 50%;
            pointer-events: none;
        }

        .hero-page .hero::after {
            content: '';
            position: absolute;
            bottom: -40%;
            left: -10%;
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, rgba(212, 175, 55, 0.05) 0%, transparent 70%);
            border-radius: 50%;
            pointer-events: none;
        }

        .hero-page .hero-content {
            position: relative;
            z-index: 2;
        }

        .hero-page .hero .avatar {
            width: 100px;
            height: 100px;
            border-radius: 50%;
            object-fit: cover;
            border: 3px solid #ffffff;
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
            margin-bottom: 20px;
        }

        .hero-page .hero h1 {
            font-size: 2.8rem;
            font-weight: 600;
            color: #0b1b33;
            letter-spacing: -0.02em;
            margin-bottom: 8px;
        }

        .hero-page .hero h1 .highlight {
            background: linear-gradient(135deg, #0066cc, #4a90d9);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .hero-page .hero .subtitle {
            font-size: 1.1rem;
            color: #4a6a8e;
            font-weight: 400;
            margin-bottom: 30px;
            letter-spacing: 0.3px;
        }

        .hero-page .hero .divider {
            width: 60px;
            height: 3px;
            background: linear-gradient(90deg, #0066cc, #4a90d9);
            border-radius: 10px;
            margin: 0 auto 30px;
        }

        .hero-page .platform-grid {
            display: flex;
            justify-content: center;
            gap: 16px;
            flex-wrap: wrap;
            margin-bottom: 10px;
        }

        .hero-page .platform-btn {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            padding: 12px 28px;
            border-radius: 60px;
            font-size: 0.95rem;
            font-weight: 500;
            color: #1a1a1a;
            background: #ffffff;
            border: 1px solid #e6ecf3;
            cursor: pointer;
            transition: all 0.2s ease;
            text-decoration: none;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.02);
        }

        .hero-page .platform-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
            border-color: #b8c8e0;
        }

        .hero-page .platform-btn.bili {
            color: #00a1d6;
            border-color: rgba(0, 161, 214, 0.2);
        }
        .hero-page .platform-btn.bili:hover {
            background: #f0f8fe;
            border-color: #00a1d6;
        }

        .hero-page .platform-btn.xhs {
            color: #ff2442;
            border-color: rgba(255, 36, 66, 0.2);
        }
        .hero-page .platform-btn.xhs:hover {
            background: #fef0f2;
            border-color: #ff2442;
        }

        .hero-page .platform-btn.douyin {
            color: #000000;
            border-color: rgba(0, 0, 0, 0.12);
        }
        .hero-page .platform-btn.douyin:hover {
            background: #f5f5f5;
            border-color: #000;
        }

        .hero-page .platform-btn.yt {
            color: #ff0000;
            border-color: rgba(255, 0, 0, 0.15);
        }
        .hero-page .platform-btn.yt:hover {
            background: #fef0f0;
            border-color: #ff0000;
        }

        .hero-page .section-label {
            font-size: 0.85rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            color: #6a7e9b;
            margin: 40px 0 20px;
            text-align: center;
        }

        .hero-page .section-label::before,
        .hero-page .section-label::after {
            content: '';
            display: inline-block;
            width: 30px;
            height: 1px;
            background: #dce3ed;
            vertical-align: middle;
            margin: 0 12px;
        }

        .hero-page .site-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            gap: 18px;
        }

        .hero-page .site-card {
            background: #ffffff;
            border-radius: 20px;
            padding: 24px 16px 20px;
            text-align: center;
            border: 1px solid #eef2f7;
            transition: all 0.25s ease;
            cursor: pointer;
            text-decoration: none;
            color: inherit;
            display: block;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.02);
        }

        .hero-page .site-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 16px 40px rgba(0, 20, 40, 0.08);
            border-color: #d0dcec;
        }

        .hero-page .site-card .emoji {
            font-size: 2.2rem;
            display: block;
            margin-bottom: 10px;
        }
        .hero-page .site-card .name {
            font-size: 1rem;
            font-weight: 600;
            color: #0b1b33;
        }
        .hero-page .site-card .desc {
            font-size: 0.8rem;
            color: #6a7e9b;
        }
        .hero-page .site-card .badge {
            display: inline-block;
            margin-top: 8px;
            padding: 2px 12px;
            border-radius: 30px;
            font-size: 0.6rem;
            font-weight: 600;
            background: #e6edf8;
            color: #2c4a7a;
        }
        .hero-page .site-card .badge.new {
            background: #0066cc;
            color: white;
        }
        .hero-page .site-card .badge.coming {
            background: #f0f0f0;
            color: #999;
        }
        .hero-page .site-card.placeholder {
            opacity: 0.6;
            cursor: not-allowed;
            filter: grayscale(0.3);
        }
        .hero-page .site-card.placeholder:hover {
            transform: none;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.02);
            border-color: #eef2f7;
        }

        .hero-page .footer-text {
            text-align: center;
            margin-top: 40px;
            font-size: 0.8rem;
            color: #8a9bb0;
            border-top: 1px solid #eef2f7;
            padding-top: 20px;
        }

        /* ===== 響應式 ===== */
        @media (max-width: 768px) {
            .navbar-wrapper {
                padding: 0.5rem 1rem;
                flex-wrap: wrap;
                gap: 6px;
            }
            .navbar-wrapper .nav-links {
                gap: 0.8rem;
            }
            .navbar-wrapper .nav-links a {
                font-size: 0.75rem;
            }
            .hero-page .hero {
                padding: 30px 20px 24px;
            }
            .hero-page .hero h1 {
                font-size: 2rem;
            }
            .hero-page .platform-btn {
                padding: 8px 16px;
                font-size: 0.8rem;
                gap: 6px;
            }
            .hero-page .site-grid {
                grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
                gap: 12px;
            }
            .page .card {
                padding: 16px;
            }
            .hero-page .section-label::before,
            .hero-page .section-label::after {
                width: 12px;
                margin: 0 6px;
            }
        }

        @media (max-width: 480px) {
            .navbar-wrapper .nav-links {
                gap: 0.5rem;
            }
            .navbar-wrapper .nav-links a {
                font-size: 0.7rem;
            }
            .hero-page .hero h1 {
                font-size: 1.6rem;
            }
            .hero-page .platform-btn {
                padding: 6px 12px;
                font-size: 0.7rem;
                gap: 4px;
            }
            .hero-page .platform-btn .icon {
                font-size: 1rem;
            }
            .hero-page .site-grid {
                grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
                gap: 10px;
            }
            .hero-page .site-card {
                padding: 14px 10px 12px;
            }
            .hero-page .site-card .emoji {
                font-size: 1.5rem;
            }
        }

        /* ============================================================
           以下是各個子頁面的樣式（全部嵌入，保持風格一致）
           ============================================================ */

        /* --- 彈窗（適用所有頁面） --- */
        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(5px);
            display: none;
            justify-content: center;
            align-items: center;
            z-index: 3000;
            cursor: pointer;
        }
        .modal-box {
            background-color: white;
            padding: 30px 35px;
            border-radius: 16px;
            text-align: center;
            max-width: 340px;
            width: 90%;
            cursor: default;
            animation: fadeIn 0.3s ease;
        }
        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: scale(0.9);
            }
            to {
                opacity: 1;
                transform: scale(1);
            }
        }
        .modal-box .title {
            font-size: 1.1rem;
            font-weight: 500;
            color: #333;
            margin-bottom: 16px;
        }
        .modal-box .divider {
            height: 1px;
            background: #e8ecf0;
            margin: 14px 0;
        }
        .contact-info {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 10px;
        }
        .qq-icon {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            object-fit: cover;
        }
        .qq-number {
            font-size: 1.6rem;
            font-weight: bold;
            color: #333;
            letter-spacing: 2px;
        }
        .qq-label {
            font-size: 0.85rem;
            color: #888;
            margin-bottom: 4px;
        }
        .platform-grid-small {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
            margin-top: 6px;
        }
        .platform-btn-small {
            display: block;
            width: 100%;
            padding: 10px 0;
            border: 1px solid #dce3ed;
            border-radius: 40px;
            background: #ffffff;
            font-size: 0.85rem;
            font-weight: 500;
            color: #1a1a1a;
            cursor: pointer;
            text-align: center;
            transition: 0.15s;
            font-family: sans-serif;
        }
        .platform-btn-small:active {
            background: #f0f0f0;
            transform: scale(0.97);
        }
        .platform-btn-small.bili {
            color: #00a1d6;
        }
        .platform-btn-small.xhs {
            color: #ff2442;
        }
        .platform-btn-small.douyin {
            color: #000000;
        }
        .platform-btn-small.yt {
            color: #ff0000;
        }
        @media (max-width: 600px) {
            .modal-box {
                padding: 20px;
                max-width: 300px;
            }
            .platform-grid-small {
                gap: 6px;
            }
            .platform-btn-small {
                padding: 8px 0;
                font-size: 0.75rem;
            }
            .qq-number {
                font-size: 1.2rem;
            }
            .qq-icon {
                width: 50px;
                height: 50px;
            }
        }

        /* --- emoji 頁面樣式 --- */
        .emoji-page .control-panel {
            background: rgba(255, 255, 255, 0.5);
            backdrop-filter: blur(3px);
            border-radius: 48px;
            padding: 16px 10px;
            margin-bottom: 16px;
            border: 1px solid #eef2f7;
        }
        .emoji-page .button-group {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 6px;
            margin-bottom: 12px;
        }
        .emoji-page .emoji-btn {
            border: 1px solid #cfddee;
            padding: 8px 18px;
            border-radius: 1024px;
            background: white;
            color: #1e2b3c;
            font-size: 0.85rem;
            font-weight: 500;
            cursor: pointer;
            transition: 0.2s;
        }
        .emoji-page .emoji-btn:hover {
            background: #e6f0ff;
            border-color: #90b8e0;
        }
        .emoji-page .slider-group {
            display: inline-flex;
            align-items: center;
            margin: 0 8px;
        }
        .emoji-page .slider-group label {
            font-weight: 500;
            color: #1e3a5f;
            margin-right: 6px;
            font-size: 0.85rem;
        }
        .emoji-page .slider-group input[type="range"] {
            width: 140px;
            height: 6px;
            background: #dbe4f0;
            border-radius: 10px;
            -webkit-appearance: none;
            appearance: none;
        }
        .emoji-page .slider-group input[type="range"]::-webkit-slider-thumb {
            -webkit-appearance: none;
            appearance: none;
            width: 18px;
            height: 18px;
            background: #0066cc;
            border-radius: 50%;
            cursor: pointer;
        }
        .emoji-page #video_wrapper,
        .emoji-page #img_wrapper {
            text-align: center;
            display: none;
            background: #ffffffd9;
            padding: 12px;
            border-radius: 24px;
            margin: 12px auto;
        }
        .emoji-page #video_wrapper video,
        .emoji-page #img_wrapper img {
            max-width: 100%;
            border-radius: 16px;
            max-height: 250px;
        }
        .emoji-page #ASCIIScreen {
            margin: 16px auto;
            line-height: 17px;
            font-size: 17px;
            background: white;
            color: #11181f;
            padding: 20px 16px;
            border-radius: 32px;
            box-shadow: 0 4px 16px rgba(0, 30, 60, 0.06);
            border: 1px solid #eef3fc;
            overflow-x: auto;
            font-family: 'Courier New', monospace;
            width: fit-content;
            min-width: 200px;
        }
        .emoji-page #drag_overlay {
            position: fixed;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background: rgba(255, 255, 255, 0.88);
            backdrop-filter: blur(4px);
            pointer-events: none;
            opacity: 0;
            z-index: 1;
        }
        .emoji-page .drag-overlay-content {
            position: absolute;
            left: 16px;
            top: 16px;
            width: calc(100% - 32px);
            height: calc(100% - 32px);
            display: grid;
            place-content: center;
            border: 3px dashed #2b4f7c;
            border-radius: 28px;
        }
        .emoji-page #canvas {
            display: none;
        }
        .emoji-page .footer-links {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 16px;
            margin-top: 20px;
            border-top: 1px dashed #b3c9e0;
            padding-top: 16px;
        }
        .emoji-page .footer-text {
            color: #5a6e88;
            font-size: 0.85rem;
        }
        .emoji-page .github-btn {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            border: 1px solid #cfddee;
            padding: 6px 20px;
            border-radius: 1024px;
            background: white;
            color: #1e2b3c;
            text-decoration: none;
            font-size: 0.85rem;
            transition: 0.2s;
        }
        .emoji-page .github-btn:hover {
            background: #e6f0ff;
        }
        .emoji-page .github-icon {
            width: 18px;
            height: 18px;
        }

        /* --- crack 頁面樣式 --- */
        .crack-page .crack-tool h2 {
            color: #333;
            font-size: 1.5rem;
            margin-bottom: 16px;
        }
        .crack-page .proxy-selector {
            margin: 12px 0;
            display: flex;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap;
        }
        .crack-page .proxy-selector select {
            flex: 1;
            padding: 8px 12px;
            border: 2px solid #e0e0e0;
            border-radius: 8px;
            font-size: 0.9rem;
            background: white;
            max-width: 400px;
            min-width: 160px;
        }
        .crack-page .proxy-selector select:focus {
            border-color: #0066cc;
            outline: none;
        }
        .crack-page .proxy-status-badge {
            display: inline-block;
            width: 12px;
            height: 12px;
            border-radius: 50%;
            flex-shrink: 0;
            transition: all 0.3s ease;
        }
        .crack-page .status-online {
            background-color: #00a86b;
            box-shadow: 0 0 8px rgba(0, 168, 107, 0.6);
        }
        .crack-page .status-offline {
            background-color: #c62828;
            box-shadow: 0 0 8px rgba(198, 40, 40, 0.4);
        }
        .crack-page .status-unknown {
            background-color: #ff9800;
            box-shadow: 0 0 8px rgba(255, 152, 0, 0.4);
            animation: pulse 1.5s infinite;
        }
        @keyframes pulse {
            0%,
            100% { opacity: 1; }
            50% { opacity: 0.4; }
        }
        .crack-page .proxy-note {
            font-size: 0.8rem;
            color: #666;
            margin-top: 4px;
            padding: 4px 12px;
            background: #f8f9fa;
            border-radius: 4px;
            border-left: 3px solid #ccc;
        }
        .crack-page .proxy-note.online {
            border-left-color: #00a86b;
        }
        .crack-page .proxy-note.offline {
            border-left-color: #c62828;
        }
        .crack-page .proxy-note.checking {
            border-left-color: #ff9800;
        }
        .crack-page .input-group {
            display: flex;
            gap: 10px;
            margin: 12px 0;
        }
        .crack-page .input-group input {
            flex: 1;
            padding: 10px 14px;
            border: 2px solid #e0e0e0;
            border-radius: 8px;
            font-size: 0.95rem;
        }
        .crack-page .input-group input:focus {
            border-color: #0066cc;
            outline: none;
        }
        .crack-page .input-group button {
            padding: 10px 24px;
            background: #0066cc;
            color: white;
            border: none;
            border-radius: 8px;
            font-weight: 600;
            cursor: pointer;
            transition: 0.2s;
        }
        .crack-page .input-group button:hover {
            background: #0052a3;
        }
        .crack-page .input-group button:disabled {
            background: #ccc;
            cursor: not-allowed;
        }
        .crack-page .mode-group {
            display: flex;
            gap: 12px;
            padding: 6px 12px;
            background: #f8f9fa;
            border-radius: 6px;
            flex-wrap: wrap;
            margin: 8px 0;
        }
        .crack-page .mode-item {
            display: flex;
            align-items: center;
            gap: 4px;
            font-size: 0.85rem;
            cursor: pointer;
        }
        .crack-page .info-box {
            background: #e3f2fd;
            padding: 8px 14px;
            border-radius: 6px;
            margin: 8px 0;
            border-left: 4px solid #0066cc;
